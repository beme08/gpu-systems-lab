#!/usr/bin/env bash
# Opt-in pre-commit hook for gpu-systems-lab.
# Scans ADDED LINES in the staged diff (git diff --cached --unified=0) for
# likely secrets and personal emails. Working tree and unstaged changes are
# not scanned (so untracked local files like hardware.md do not block).
#
# The .githooks/ directory is skipped (the patterns are documented there as
# text, so a self-scan would be a guaranteed false positive).
#
# To enable:  git config core.hooksPath .githooks
# To bypass:  git commit --no-verify

# Note: do not use `set -u` because portable /bin/bash (3.2 on macOS) does
# not support `mapfile` and positional-arg juggling is fragile. The script
# is a straight-line scan with explicit checks.

BYPASS_HINT='Bypass: `git commit --no-verify` (intentional secrets / emails).'

# Patterns for common secret formats. Format: '<regex>|<human label>'.
SECRET_PATTERNS=(
  'sk-[A-Za-z0-9_-]{20,}|OpenAI API key'
  'AKIA[0-9A-Z]{16}|AWS access key id'
  'ghp_[A-Za-z0-9]{36}|GitHub personal access token'
  'gho_[A-Za-z0-9]{36}|GitHub OAuth token'
  'github_pat_[A-Za-z0-9_]{22,}|GitHub fine-grained PAT'
  '-----BEGIN .* PRIVATE KEY-----|PEM private key'
)

# Email allowlist (extended-regex fragments). If any fragment matches, allow.
EMAIL_ALLOWLIST=(
  '\.test([[:space:]]|/|$)'
  '\.example([[:space:]]|/|$)'
  '\.sample([[:space:]]|/|$)'
  'example\.com'
  'example\.org'
  'example\.net'
  'company\.com'
  'you@company\.com'
  'noreply@github\.com'
  'noreply@users\.noreply\.github\.com'
  'users\.noreply\.github\.com'
)

# File-name rules. Reject staged additions of these names (anywhere in the path).
DISALLOW_PATH_RE='(^|/)\.env(\.[^/]+)?$'
ALLOW_PATH_RE='(^|/)\.env\.(example|sample|template)$'

# Email detector: any [A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}
EMAIL_RE='[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}'

# Path filter: skip the .githooks/ directory (it documents the patterns as text).
PATH_EXCLUDE_RE='^\.githooks/'

# Build the per-file list of staged files, excluding .githooks/.
# Stored as a newline-separated string in $STAGED_FILES (avoids bash 4+ mapfile
# and positional-arg fragility in functions).
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null \
  | grep -E -v -e "$PATH_EXCLUDE_RE" || true)

if [[ -z "$STAGED_FILES" ]]; then
  echo "pre-commit: no staged files to scan (after path filter)"
  echo "$BYPASS_HINT"
  exit 0
fi

file_count=$(echo "$STAGED_FILES" | wc -l | tr -d ' ')

fail=0
findings=0

scan_secret() {
  local label="$1" pattern="$2"
  local hits
  hits=$(git diff --cached --unified=0 --no-color -- $STAGED_FILES 2>/dev/null \
    | grep -E '^\+' \
    | grep -v -E '^(\+\+\+ |--- )' \
    | grep -E -e "$pattern" \
    || true)
  if [[ -n "$hits" ]]; then
    while IFS= read -r line; do
      local shown="${line#+}"
      echo "secret: $label  ->  $shown"
      findings=$((findings + 1))
    done <<< "$hits"
    fail=1
  fi
}

echo "pre-commit: scanning staged diff (added lines only; $file_count file(s))"
echo "$BYPASS_HINT"

# --- File-name rules ---------------------------------------------------------
STAGED_NEW_FILES=$(git diff --cached --name-only --diff-filter=A 2>/dev/null \
  | grep -E -v -e "$PATH_EXCLUDE_RE" || true)
if [[ -n "$STAGED_NEW_FILES" ]]; then
  while IFS= read -r path; do
    [[ -z "$path" ]] && continue
    if [[ "$path" =~ $DISALLOW_PATH_RE ]] && [[ ! "$path" =~ $ALLOW_PATH_RE ]]; then
      echo "secret: dotenv file staged  ->  $path"
      findings=$((findings + 1))
      fail=1
    fi
  done <<< "$STAGED_NEW_FILES"
fi

# --- Secret patterns ---------------------------------------------------------
for entry in "${SECRET_PATTERNS[@]}"; do
  pat="${entry%%|*}"
  label="${entry##*|}"
  scan_secret "$label" "$pat"
done

# --- Email detection ---------------------------------------------------------
allow_alt=$(IFS='|'; echo "${EMAIL_ALLOWLIST[*]}")
email_hits=$(git diff --cached --unified=0 --no-color -- $STAGED_FILES 2>/dev/null \
  | grep -E '^\+' \
  | grep -v -E '^(\+\+\+ |--- )' \
  | grep -E -e "$EMAIL_RE" \
  || true)
if [[ -n "$email_hits" ]]; then
  while IFS= read -r line; do
    shown="${line#+}"
    if echo "$shown" | grep -E -e "$allow_alt" >/dev/null 2>&1; then
      continue
    fi
    matched=$(echo "$shown" | grep -E -o -e "$EMAIL_RE" | head -1 || true)
    echo "email: non-allowlist address  ->  $matched  in  $shown"
    findings=$((findings + 1))
    fail=1
  done <<< "$email_hits"
fi

if [[ "$fail" -ne 0 ]]; then
  echo
  echo "pre-commit: $findings finding(s). Commit blocked."
  echo "$BYPASS_HINT"
  exit 1
fi

echo "pre-commit: clean"
exit 0
